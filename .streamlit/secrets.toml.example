# Streamlit Cloud Secrets — copy this structure to your Streamlit Cloud dashboard
# Go to: share.streamlit.io → Your app → Settings → Secrets
# Paste this (with your actual key):

OPENAI_API_KEY = "sk-your-openai-api-key-here"

