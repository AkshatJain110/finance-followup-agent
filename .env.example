# ─────────────────────────────────────────────
# Finance Follow-Up Agent — Environment Config
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Required — OpenAI API key for GPT-4o-mini
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional — LangSmith tracing (observability dashboard)
# Create free account at: https://smith.langchain.com
# Leave blank to disable tracing
LANGCHAIN_API_KEY=your-langsmith-api-key-here
